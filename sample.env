# ── Server ────────────────────────────────────────────────────────────────────

# HTTP port the server listens on.
PORT=3000

# Bind address logged on startup.
HOST=localhost


# ── Authentication ────────────────────────────────────────────────────────────

# Password for the web UI login.
APP_PASSWORD=kanban-pwd

# Static API key for external/headless access (e.g. n8n, curl).
# Accepted via x-api-key header or Authorization: Bearer <key>.
# If unset, only session tokens from the login flow are accepted.
# Use a strong random value of at least 32 characters in production.
API_KEY=


# ── CouchDB ───────────────────────────────────────────────────────────────────

# CouchDB hostname. Set to "couchdb" when using docker compose.
COUCHDB_HOST=localhost

# CouchDB port.
COUCHDB_PORT=5984

# CouchDB admin username.
COUCHDB_USER=kanban

# CouchDB admin password.
COUCHDB_PASSWORD=kanban-pwd


# ── Storage & backups ─────────────────────────────────────────────────────────

# Directory for JSON backups and file attachments (relative to app/).
BACKUP_DIR=data

# How often automatic JSON backups run, in milliseconds. Default: 10 minutes.
BACKUP_INTERVAL_MS=600000


# ── Debugging ─────────────────────────────────────────────────────────────────

# Set to "true" to log every API request and its JSON response to stdout.
LOG_API_RESPONSES=false


# ── Backup script (backup.py) ─────────────────────────────────────────────────

# Target directory for backup ZIP files (relative to project root).
BACKUP_SCRIPT_DIR=backup

# Docker compose service name for CouchDB (used to locate the container).
COUCHDB_SERVICE=couchdb

# Path to CouchDB data inside the container.
COUCHDB_DATA_PATH=/opt/couchdb/data
